# Copy this to .env.local and fill in values.
# AWS outputs (from `cdk deploy`) go in the Cognito section.
# RDS credentials come from AWS Secrets Manager after the first deploy.

# ── AWS / Cognito (public — safe to expose) ──────────────────────────────────
NEXT_PUBLIC_AWS_REGION=us-east-1
# From CDK output: GrandHealth-staging-UserPoolId
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# From CDK output: GrandHealth-staging-UserPoolClientId
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# Cognito hosted-UI domain (for OAuth flows, optional for password auth)
# Format: https://grand-health-staging.auth.us-east-1.amazoncognito.com
NEXT_PUBLIC_COGNITO_DOMAIN=

# ── RDS Postgres (server-only — never expose) ─────────────────────────────────
# From AWS Secrets Manager after `cdk deploy`.
# Format: postgresql://grandhealth:<password>@<rds-endpoint>:5432/grandhealth
DATABASE_URL=postgresql://grandhealth:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/grandhealth
# Same but without SSL forced — used by drizzle-kit for migrations locally
DIRECT_DATABASE_URL=postgresql://grandhealth:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/grandhealth
# Service-role DB connection (bypasses RLS — for cron jobs and seed scripts)
# Usually the same as DATABASE_URL but connects as a superuser or rls-bypass role
SERVICE_ROLE_DATABASE_URL=postgresql://grandhealth:YOUR_DB_PASSWORD@YOUR_RDS_ENDPOINT:5432/grandhealth

# ── Where the app is hosted ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# USDA FoodData Central API key.
# Free signup (instant): https://fdc.nal.usda.gov/api-key-signup.html
# You can use DEMO_KEY for local testing — rate-limited but works.
USDA_API_KEY=DEMO_KEY

# -------------------------------------------------------------------------
# Wearables OAuth + webhooks
# -------------------------------------------------------------------------
# Oura: https://cloud.ouraring.com/oauth/applications (create an app)
#   Redirect URI must be: ${NEXT_PUBLIC_SITE_URL}/api/wearables/oura/callback
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
# Optional — only set in production. HMAC-SHA256 (hex) of the raw body.
OURA_WEBHOOK_SECRET=

# Whoop: https://developer.whoop.com/ (create an app)
#   Redirect URI must be: ${NEXT_PUBLIC_SITE_URL}/api/wearables/whoop/callback
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Optional — HMAC-SHA256 (base64) of the raw body.
WHOOP_WEBHOOK_SECRET=

# Daily backfill cron — generate with: openssl rand -hex 32
# Pass as `x-cron-token` header (or ?token=) to POST /api/wearables/sync.
WEARABLES_CRON_TOKEN=

# -------------------------------------------------------------------------
# Cloudinary — workout video storage
# -------------------------------------------------------------------------
# Sign up at https://cloudinary.com (free tier is fine for most clinics).
# Dashboard → Settings → API Keys.
# Videos are uploaded directly from the browser to Cloudinary; our server
# only generates the upload signature so the API secret is never exposed.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
